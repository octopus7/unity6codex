<ui:UXML xmlns:ui="UnityEngine.UIElements">
    <ui:VisualElement name="lab-root" class="lab-root">
        <ui:VisualElement class="lab-panel">
            <ui:VisualElement class="lab-header">
                <ui:Label text="UI Toolkit Hands-On Lab" class="lab-title" />
                <ui:Label name="lesson-progress" text="Step 1/3" class="lab-progress" />
            </ui:VisualElement>

            <ui:Label name="lesson-title" text="Step Title" class="lesson-title" />
            <ui:Label name="lesson-objective" text="Step objective" class="lesson-objective" />
            <ui:Label name="lesson-checklist" text="Checklist" class="lesson-checklist" />

            <ui:VisualElement name="lesson-stage" class="lesson-stage" />

            <ui:VisualElement class="lab-footer">
                <ui:Button name="lesson-prev" text="Previous" class="nav-button" />
                <ui:Button name="lesson-reset" text="Reset Step" class="nav-button nav-button--accent" />
                <ui:Button name="lesson-next" text="Next" class="nav-button" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
